# original-esp32-wifi-climate build configuration
#
# Copy this file to `.env` and fill in your own values:
#     cp .env.example .env
#
# `.env` is gitignored and MUST NOT be committed — it holds real secrets.
# build.rs loads these into compile-time env (`env!`).

# WiFi network the ESP32 connects to
WIFI_SSID=your-wifi-ssid
WIFI_PSK=your-wifi-password

# Raspberry Pi IoT server that receives sensor readings (POST /api/sensors/reading)
RASPI_IP=192.168.1.100

# Logical device identifier reported to the server
DEVICE_ID=living-room

# Shared secret required in the `X-OTA-Token` header of `POST /switch`.
# Must match the OTA_AUTH_TOKEN the updater firmware was built with.
OTA_AUTH_TOKEN=change-me
